{
  "mcpServers": {
    "walrusvault": {
      "command": "node",
      "args": ["./mcp-server.js"],
      "env": {
        "TATUM_API_KEY": "t-66d664aaa620a5001c9ee388-9459a9dd66ad42e2874171fe",
        "WALRUS_ENDPOINT": "https://walrus-testnet-publisher.nodes.guru",
        "SUI_RPC_URL": "https://sui-testnet.tatum.io"
      }
    }
  },
  "tools": {
    "uploadFile": {
      "description": "Upload encrypted file to Walrus and register on SUI blockchain",
      "inputSchema": {
        "type": "object",
        "properties": {
          "filePath": {
            "type": "string",
            "description": "Path to file to upload"
          },
          "password": {
            "type": "string",
            "description": "Encryption password"
          },
          "walletAddress": {
            "type": "string",
            "description": "SUI wallet address"
          }
        },
        "required": ["filePath", "password", "walletAddress"]
      }
    },
    "downloadFile": {
      "description": "Download and decrypt file from Walrus",
      "inputSchema": {
        "type": "object",
        "properties": {
          "blobId": {
            "type": "string",
            "description": "Walrus blob ID"
          },
          "password": {
            "type": "string",
            "description": "Decryption password"
          }
        },
        "required": ["blobId", "password"]
      }
    },
    "getFileMetadata": {
      "description": "Get file metadata from SUI blockchain",
      "inputSchema": {
        "type": "object",
        "properties": {
          "fileHash": {
            "type": "string",
            "description": "File SHA-256 hash"
          }
        },
        "required": ["fileHash"]
      }
    },
    "verifyFileIntegrity": {
      "description": "Verify file integrity using blockchain hash",
      "inputSchema": {
        "type": "object",
        "properties": {
          "blobId": {
            "type": "string",
            "description": "Walrus blob ID"
          },
          "expectedHash": {
            "type": "string",
            "description": "Expected SHA-256 hash"
          }
        },
        "required": ["blobId", "expectedHash"]
      }
    }
  }
}
